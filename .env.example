# Career Card agent providers
#
# The agent always falls back to the deterministic rules provider when a model
# provider is missing, unavailable, or returns invalid JSON.

# DeepSeek uses an OpenAI-compatible chat completions endpoint.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Mimo is configurable because deployments may expose different compatible URLs.
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL=mimo-v2-flash

# Optional request timeout for model-backed providers.
CAREER_AGENT_TIMEOUT_MS=20000
