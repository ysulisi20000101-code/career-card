# AI Provider (required for AI features)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# API Authentication (optional, leave empty to allow all requests in dev)
API_SECRET=

# Storage Adapter (json-file for local dev, edgeone-kv for production)
STORAGE_ADAPTER=json-file
